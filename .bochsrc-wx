config_interface: wx

display_library: wx
#display_library: x

romimage: file=/usr/share/bochs/BIOS-bochs-latest, address=0xfffe0000
#romimage: file=/usr/share/bochs/BIOS-bochs-legacy,address=0xfffe0000
#romimage: file=mybios.bin, address=0xfff80000 # 512k at memory top
#romimage: file=mybios.bin # calculate start address from image size

cpu: count=1, ips=10000000
megs: 256

vgaromimage: file=/usr/share/vgabios/vgabios.bin    # Oui ?
#vgaromimage: file=/usr/share/vgabios/vgabios.debug.bin

#vga: extension=cirrus
#vga: extension=vbe # Oui ?
vga: extension=none

floppya: 1_44=./manux, status=inserted
boot: floppy
floppy_bootsig_check: disabled=0

log: /dev/stdout
panic: action=fatal
error: action=report
info: action=report
debug: action=ignore
#pass: action=fatal


debugger_log: -

# Configuration du clavier
keyboard: type=mf, serial_delay=250, paste_delay=100000
keyboard: user_shortcut=ctrl-alt-del
#keyboard: keymap=/usr/share/bochs/keymaps/x11-pc-uk.map


mouse: enabled=0

private_colormap: enabled=0

