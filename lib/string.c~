#include <manux/string.h>

void bcopy (const void *src, void *dest, int n)
/*
 * WARNING ŗ rťťcrire en assembleur
 */
{
   int i;

   for (i = 0; i < n; i++) {
     ((char *)dest)[i] = ((char *)src)[i];
   }
}
